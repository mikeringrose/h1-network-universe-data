# PostgreSQL connection (pydantic-settings loads this).
# Matches docker-compose.yml defaults: cp .env.example .env then run: docker compose up -d
DATABASE_URL=postgresql://user:password@localhost:5432/pipeline
# API database — where org_files table lives (managed by the Node.js API)
API_DATABASE_URL=postgresql://user:password@localhost:5432/api

# Directory containing input files (CSV, Excel)
DATA_DIR=data

# AWS / SQS (set for LocalStack local dev)
SQS_QUEUE_URL=http://localhost:4566/000000000000/org-files
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
